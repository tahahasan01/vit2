# ============================================
# THE DIRTY LAUNDRY V2 — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── General ──────────────────────────────────
ENVIRONMENT=development          # development | staging | production
USE_STUBS=true                   # true = mock all external APIs (no keys needed)
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Supabase (Storage + Auth + Realtime + DB) ─
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Replicate (VTO + 3D + Video inference) ───
REPLICATE_API_TOKEN=r8_your_replicate_token

# ── Redis (ARQ Job Queue) ────────────────────
REDIS_URL=redis://localhost:6379/0
# For Upstash (free tier):
# REDIS_URL=rediss://default:your-password@your-host.upstash.io:6379

# ── Pipeline Tuning ──────────────────────────
VTO_MODEL_ID=cuuupid/idm-vton
VTO_FALLBACK_MODEL_ID=subhash25rawat/flux-vton
TRELLIS_MODEL_ID=firtoz/trellis
VIDEO_MODEL_ID=wan-video/wan-2.2-i2v-fast
HMR_SPACE_URL=https://brjathu-hmr2-0.hf.space
PIPELINE_TIMEOUT_SECONDS=300
MAX_CONCURRENT_JOBS=10

# ── Frontend (Vite env vars must start with VITE_) ─
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
